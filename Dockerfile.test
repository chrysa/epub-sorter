FROM python:3.14-slim AS deps

WORKDIR /app

RUN pip install --only-binary :all: --upgrade pip setuptools wheel

COPY requirements.txt ./
# ebookmeta/progress are pure-Python packages; wheels not always available on PyPI
RUN pip install ebookmeta==1.2.11 progress==1.6.1
RUN pip install --only-binary :all: "pytest>=8.0" "pytest-cov>=5.0"

FROM deps AS test

# Copy only necessary files to avoid inadvertently adding sensitive data
COPY *.py ./
COPY tests/ ./tests/

# Run as non-root user
RUN useradd --create-home appuser
USER appuser

ENV PYTHONPATH=/app

CMD ["pytest", "--cov=.", "--cov-branch", \
    "--cov-report=xml:coverage.xml", \
    "--cov-report=term-missing", \
    "--ignore=gui.py", "--ignore=main.py"]
